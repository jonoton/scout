{
    "swagger": "2.0",
    "info": {
        "description": "This is the API for Scout, a video monitoring system.",
        "title": "Scout API",
        "contact": {},
        "version": "1.0"
    },
    "paths": {
        "/": {
            "get": {
                "description": "Serve the index.html template for the Scout dashboard.",
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "UI"
                ],
                "summary": "Access Dashboard",
                "responses": {
                    "200": {
                        "description": "HTML content",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/alerts/files/{name}": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Retrieve a specific alert JPG file.",
                "tags": [
                    "Alerts"
                ],
                "summary": "Get alert file",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filename",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Alert image",
                        "schema": {
                            "type": "file"
                        }
                    }
                }
            }
        },
        "/alerts/latest": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Get the latest alert timestamps for Object, Person, and Face detections across all monitors.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Alerts"
                ],
                "summary": "Get Latest Alerts",
                "responses": {
                    "200": {
                        "description": "Latest alert times by monitor (RFC3339 format)",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "object",
                                "additionalProperties": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/alerts/list": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Get a list of alert JPG files, sorted descending by time.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Alerts"
                ],
                "summary": "List alerts",
                "responses": {
                    "200": {
                        "description": "List of alert filenames",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/continuous/files/{name}": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Retrieve a specific continuous recording file.",
                "tags": [
                    "Continuous"
                ],
                "summary": "Get continuous file",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filename",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Continuous recording file",
                        "schema": {
                            "type": "file"
                        }
                    }
                }
            }
        },
        "/continuous/list": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Get a list of continuous recordings, sorted descending by time.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Continuous"
                ],
                "summary": "List continuous recordings",
                "responses": {
                    "200": {
                        "description": "List of continuous filenames",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/heartbeat": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Check if the Scout server is responsive.",
                "tags": [
                    "System"
                ],
                "summary": "System Heartbeat",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/info/list": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Get a list of all available monitor names, including those from linked Scout instances.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Info"
                ],
                "summary": "List Monitors",
                "responses": {
                    "200": {
                        "description": "List of monitor names",
                        "schema": {
                            "$ref": "#/definitions/http.nameListResp"
                        }
                    }
                }
            }
        },
        "/info/{name}": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Get detailed information (FPS, etc.) for a specific monitor by name.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Info"
                ],
                "summary": "Get Monitor Info",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Monitor Name",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Monitor information",
                        "schema": {
                            "$ref": "#/definitions/http.monInfoResp"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/live/{name}": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Real-time video stream via websocket.",
                "tags": [
                    "Monitor"
                ],
                "summary": "Live monitor websocket",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Monitor Name",
                        "name": "name",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Width",
                        "name": "width",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "JPEG Quality",
                        "name": "quality",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Auth Token",
                        "name": "token",
                        "in": "query"
                    }
                ],
                "responses": {
                    "101": {
                        "description": "Switching Protocols",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/login": {
            "post": {
                "description": "Authenticate user and return a JWT token or two-factor options.",
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Login to the system",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Username",
                        "name": "a",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Password",
                        "name": "b",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Two-factor option index",
                        "name": "y",
                        "in": "formData"
                    },
                    {
                        "type": "string",
                        "description": "Two-factor secret",
                        "name": "z",
                        "in": "formData"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success (returns JWT token 'c', timeout 't', or options 'o')",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/memory": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Get current memory usage statistics for the application and system.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "System"
                ],
                "summary": "Get Memory Usage",
                "responses": {
                    "200": {
                        "description": "Memory usage info in MB",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "integer"
                            }
                        }
                    }
                }
            }
        },
        "/recordings/files/{name}": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Retrieve a specific motion recording file.",
                "tags": [
                    "Recordings"
                ],
                "summary": "Get recording file",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filename",
                        "name": "name",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Recording file",
                        "schema": {
                            "type": "file"
                        }
                    }
                }
            }
        },
        "/recordings/list": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Get a list of motion recordings, sorted descending by time.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Recordings"
                ],
                "summary": "List recordings",
                "responses": {
                    "200": {
                        "description": "List of recording filenames",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "http.monInfoResp": {
            "type": "object",
            "properties": {
                "Name": {
                    "type": "string"
                },
                "ReaderInFps": {
                    "type": "integer"
                },
                "ReaderOutFps": {
                    "type": "integer"
                }
            }
        },
        "http.nameListResp": {
            "type": "object",
            "properties": {
                "NameList": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "description": "Type \"Bearer \" followed by a space and JWT token.",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}